# ═══════════════════════════════════════════════════
# Dolphin Server Modules — Environment Variables
# ═══════════════════════════════════════════════════
# यो file copy गर्नुहोस्: cp .env.example .env
# .env file कहिल्यै git मा push गर्नु हुन्न!
# ═══════════════════════════════════════════════════

# ─── Required ───────────────────────────────────────
NODE_ENV=development                  # development | production

PORT=3000

MONGO_URI=mongodb://localhost:27017/dolphin_db
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/dbname

# JWT — minimum 32 random characters
JWT_SECRET=change_this_to_a_random_string_minimum_32_chars

# ─── Auth Options ───────────────────────────────────
# Encryption key for 2FA TOTP secret storage
ENCRYPTION_KEY=another_random_string_for_2fa_encryption_32chars

# Your app's public URL (used in password reset emails)
APP_URL=http://localhost:3000

# ─── Optional: Redis ────────────────────────────────
# Needed for: rate limiting at scale, multi-server realtime
# REDIS_URL=redis://localhost:6379

# ─── Optional: AI Features (dolphin generate / chat) ─
# Only ONE key is needed
# GEMINI_API_KEY=your_gemini_api_key
# GROQ_API_KEY=your_groq_api_key
# OPENAI_API_KEY=your_openai_api_key

# Local AI (free, offline)
# USE_OLLAMA=true
# OLLAMA_MODEL=gemma3:latest

# ─── Production Only ────────────────────────────────
# FRONTEND_URL=https://myfrontend.com    # CORS origin
