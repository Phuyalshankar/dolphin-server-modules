{
  "name": "dolphin-phone",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start:server": "cd server && node index.js",
    "start:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run start:server\" \"npm run start:client\"",
    "install:all": "cd server && npm install && cd ../client && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
