{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "declaration": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "jest"]
  },
  "include": [
    "server/**/*",
    "auth/**/*",
    "authController/**/*",
    "controller/**/*",
    "curd/**/*",
    "middleware/**/*",
    "realtime/**/*",
    "adapters/**/*",
    "router/**/*",
    "swagger/**/*",
    "djson/**/*",
    "index.ts",
    "demo-server.ts"
  ],
  "exclude": ["node_modules", "dist"]
}