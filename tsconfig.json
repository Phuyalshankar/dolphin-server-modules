{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "declaration": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "jest"]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/client/**/*",
    "src/**/*.test.ts",
    "src/test-dolphin.ts",
    "src/test-2fa-real.ts",
    "src/real-test-mongoose.ts",
    "src/demo-server.ts",
    "src/dolphin-bench.ts",
    "src/performance-test.ts",
    "src/hard-performance-test.ts",
    "src/client_dom.test.ts",
    "src/client.test.ts"
  ]
}
