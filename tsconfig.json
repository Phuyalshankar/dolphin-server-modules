{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "declaration": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "jest"]
  },
  "include": [
    "server/**/*",        // ← यो थप्नुहोस् (सबै server फोल्डर)
    "server.ts",          // ← यो पनि थप्नुहोस्
    "auth/**/*",
    "authController/**/*",          
    "controller/**/*",
    "curd/**/*",
    "middleware/**/*",
    "realtime/**/*",
    "adapters/**/*",
    "index.ts"
  ],
  "exclude": ["node_modules", "dist"]
}